{{ >header }}

<h2>Adicionar Post</h2>

<form method="post">
    <div>
        <input placeholder="Titulo" name="title" type="text" />
    </div>
    <br />
    <div>
        <input placeholder="Corpo" name="body" type="text" />
    </div>
    <br />
    <div>
        <button type="submit">Login</button>
    </div>
</form>